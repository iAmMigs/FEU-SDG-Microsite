<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}FEU SDG Microsite{% endblock %}</title>
        
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
        
        {% block stylesheets %}
            {# 1. Load Eudeka Template CSS FIRST #}
            <link rel="stylesheet" href="{{ asset('eudeka/css/bootstrap.min.css') }}">
            <link rel="stylesheet" href="{{ asset('eudeka/css/style.css') }}">
            
            {# 2. Load Tailwind CSS LAST (so it overrides template styles) #}
            <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
        {% endblock %}

        {% block javascripts %}
            {# Symfony UX & AssetMapper #}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    
    <body class="flex flex-col min-h-screen font-sans text-gray-900 bg-white">

        {# Page Loader Overlay #}
        <div id="page-loader" class="fixed inset-0 z-[99999] bg-[#FCFCFC] flex flex-col items-center justify-center transition-opacity duration-500">
            <img src="{{ asset('images/loader.gif') }}" alt="Loading..." class="w-30 h-30 object-contain">
            <p class="mt-6 text-feu-green-800 font-bold tracking-widest uppercase text-sm animate-pulse">Loading...</p>
        </div>
        
        {# 1. Include Header #}
        {% include 'SDG-Microsite/partials/header.html.twig' %}

        {# 2. Main Content Area #}
        <main class="flex-grow">
            {% block body %}{% endblock %}
        </main>

        {# 3. Include Footer #}
        {% include 'SDG-Microsite/partials/footer.html.twig' %}

        {# 4. Load Template Javascripts at the bottom #}
        {% block template_javascripts %}
            <script src="{{ asset('eudeka/js/jquery-3.6.0.min.js') }}"></script>
            <script src="{{ asset('eudeka/js/bootstrap.bundle.min.js') }}"></script>
            <script src="{{ asset('eudeka/js/main.js') }}"></script>
        {% endblock %}
    </body>
</html>