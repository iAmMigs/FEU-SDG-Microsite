{% extends 'SDG-Microsite/base.html.twig' %}

{% block title %}About - FEU SDG Microsite{% endblock %}

{% block body %}
    <section class="bg-feu-green-900 py-16 px-6 text-center border-b-4 border-feu-gold-400">
        <div class="max-w-4xl mx-auto">
            <h1 class="text-4xl md:text-5xl font-bold text-white mb-4 font-bebas tracking-wide">About the Microsite</h1>
            <p class="text-lg text-feu-green-50 font-medium font-work max-w-2xl mx-auto">
                Learn more about Far Eastern University's commitment to tech-driven innovation and sustainable development.
            </p>
        </div>
    </section>

    <section class="py-20 px-6 bg-white">
        <div class="max-w-4xl mx-auto text-center">
            <h2 class="text-3xl font-bold text-gray-900 mb-6 font-bebas tracking-wide">Tech-Driven Solutions for a Better World</h2>
            <div class="w-24 h-1 bg-feu-gold-400 mx-auto mb-8"></div>
            <p class="text-gray-800 font-medium text-lg leading-relaxed font-work mb-6">
                At Far Eastern University Institute of Technology, we believe that the greatest challenges of our generation can be solved through the strategic application of technology and engineering. This microsite serves as a centralized hub to showcase our continuous efforts in aligning academic excellence with the United Nations Sustainable Development Goals (SDGs).
            </p>
            <p class="text-gray-800 font-medium text-lg leading-relaxed font-work">
                By tracking student theses, faculty research, and community extension programs, we aim to foster transparency, inspire future innovators, and measure our tangible impact on local and global communities.
            </p>
        </div>
    </section>

    <section class="relative py-24 px-6 overflow-hidden border-t-4 border-feu-gold-400">
        
        <div class="absolute inset-0 z-0">
            <img src="{{ asset('images/hero-2.jpg') }}" alt="FEU Campus" class="w-full h-full object-cover">
            <div class="absolute inset-0 bg-feu-green-950/80 mix-blend-multiply"></div>

            <div class="absolute inset-0 bg-feu-green-900/70 mix-blend-multiply"></div>
        </div>

        <div class="relative z-10 max-w-7xl mx-auto">
            <div class="text-center mb-16">
                <h2 class="text-4xl md:text-5xl font-bold text-white font-bebas tracking-wide">Our Core Pillars</h2>
                <p class="text-feu-green-50 font-medium mt-3 text-lg font-work">The foundation of our sustainability initiatives.</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                
                <div class="bg-white p-10 rounded-2xl shadow-xl hover:-translate-y-2 transition duration-300 border-b-4 border-feu-green-600">
                    <div class="w-14 h-14 bg-feu-green-100 rounded-xl flex items-center justify-center mb-6 border border-feu-green-200">
                        <svg class="w-7 h-7 text-feu-green-800" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
                    </div>
                    <h3 class="text-xl font-bold text-gray-900 mb-3 font-bebas tracking-wide">Academic Research</h3>
                    <p class="text-gray-800 font-medium text-sm leading-relaxed font-work">
                        Empowering students to focus their capstone projects and academic theses on resolving real-world sustainability bottlenecks using modern technology.
                    </p>
                </div>

                <div class="bg-white p-10 rounded-2xl shadow-xl hover:-translate-y-2 transition duration-300 border-b-4 border-feu-gold-500">
                    <div class="w-14 h-14 bg-feu-gold-100 rounded-xl flex items-center justify-center mb-6 border border-feu-gold-200">
                        <svg class="w-7 h-7 text-feu-gold-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
                    </div>
                    <h3 class="text-xl font-bold text-gray-900 mb-3 font-bebas tracking-wide">Community Extension</h3>
                    <p class="text-gray-800 font-medium text-sm leading-relaxed font-work">
                        Translating complex engineering solutions into accessible, community-driven programs that directly uplift local barangays and partner organizations.
                    </p>
                </div>

                <div class="bg-white p-10 rounded-2xl shadow-xl hover:-translate-y-2 transition duration-300 border-b-4 border-feu-green-600">
                    <div class="w-14 h-14 bg-feu-green-100 rounded-xl flex items-center justify-center mb-6 border border-feu-green-200">
                        <svg class="w-7 h-7 text-feu-green-800" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                    </div>
                    <h3 class="text-xl font-bold text-gray-900 mb-3 font-bebas tracking-wide">Sustainable Innovation</h3>
                    <p class="text-gray-800 font-medium text-sm leading-relaxed font-work">
                        Fostering a culture of green tech and eco-friendly engineering, ensuring that our technical advancements do not come at the cost of the environment.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <section class="py-20 px-6 bg-feu-green-900 text-center">
        <div class="max-w-3xl mx-auto">
            <h2 class="text-3xl font-bold text-white mb-6 font-bebas tracking-wide">Contribute to the Future</h2>
            <p class="text-feu-green-50 font-medium text-lg mb-10 font-work leading-relaxed">
                Are you an FEU student or faculty member working on a project that aligns with the UN Sustainable Development Goals? Submit your research to be featured in our global library.
            </p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
                <a href="{{ path('app_library') }}" class="bg-feu-gold-400 hover:bg-feu-gold-500 text-feu-green-950 font-bold py-3 px-8 rounded-full transition shadow-lg font-work">
                    Browse the Library
                </a>
                <a href="#" class="bg-transparent hover:bg-feu-green-800 border-2 border-feu-green-400 text-white font-bold py-3 px-8 rounded-full transition font-work">
                    Submit a Project
                </a>
            </div>
        </div>
    </section>
{% endblock %}