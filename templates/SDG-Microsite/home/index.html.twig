{% extends 'SDG-Microsite/base.html.twig' %}

{% block title %}FEU SDG Microsite - Advancing Sustainability{% endblock %}

{% block body %}
    <section class="relative h-screen w-full bg-green-950 text-white overflow-hidden" data-controller="carousel">
    
    <div class="absolute inset-0 z-0 pointer-events-none">
        <img data-carousel-target="slide" src="{{ asset('images/hero-1.jpg') }}" class="absolute inset-0 w-full h-full object-cover transition-opacity duration-1000 opacity-0" alt="FEU Campus 1">
        <img data-carousel-target="slide" src="{{ asset('images/hero-2.jpg') }}" class="absolute inset-0 w-full h-full object-cover transition-opacity duration-1000 opacity-0" alt="FEU Campus 2">
        <img data-carousel-target="slide" src="{{ asset('images/hero-3.jpg') }}" class="absolute inset-0 w-full h-full object-cover transition-opacity duration-1000 opacity-0" alt="FEU Campus 3">
        <img data-carousel-target="slide" src="{{ asset('images/hero-4.jpg') }}" class="absolute inset-0 w-full h-full object-cover transition-opacity duration-1000 opacity-0" alt="FEU Campus 4">
        
        <div class="absolute inset-0 bg-green-950/60 mix-blend-multiply"></div>
    </div>

    <div class="relative h-full max-w-7xl mx-auto flex flex-col items-center justify-center text-center z-10 px-6">
        <h1 class="text-5xl md:text-7xl font-bold tracking-tight mb-6 font-bebas">
            Driving Sustainable Impact at FEU
        </h1>
        <p class="text-lg md:text-2xl max-w-3xl mb-10 text-green-50 font-work">
            Explore our research, student theses, and community projects dedicated to solving global challenges through local action.
        </p>
        <a href="#goals" class="bg-[#FCC30B] text-green-950 px-10 py-4 rounded-full font-bold text-lg hover:bg-yellow-300 transition duration-300 shadow-xl">
            Explore Our Focus Goals
        </a>
    </div>
</section>

    <section id="goals" class="py-20 px-6 bg-gray-50">
        <div class="max-w-7xl mx-auto">
            <div class="text-center mb-16">
                <h2 class="text-3xl font-bold text-gray-900 mb-4">Our SDG Focus Areas</h2>
                <p class="text-gray-600 max-w-2xl mx-auto">FEU aligns its academic research, student theses, and institutional projects specifically toward these 8 key Sustainable Development Goals.</p>
            </div>

            <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-6">
                
                <a href="{{ path('app_library') }}?goals[]=3" class="block group relative rounded-xl overflow-hidden shadow-sm hover:shadow-2xl transition-all duration-300 hover:-translate-y-1.5 border border-gray-100 bg-white aspect-square">
                    <img src="{{ asset('images/sdg-3.jpg') }}" alt="Goal 3: Good Health and Well-Being" class="absolute inset-0 w-full h-full object-cover transition-opacity duration-300 opacity-100 group-hover:opacity-0">
                    <img src="{{ asset('images/sdg-3-inv.jpg') }}" alt="Goal 3: Good Health and Well-Being" class="absolute inset-0 w-full h-full object-cover transition-opacity duration-300 opacity-0 group-hover:opacity-100">
                </a>

                <a href="{{ path('app_library') }}?goals[]=4" class="block group relative rounded-xl overflow-hidden shadow-sm hover:shadow-2xl transition-all duration-300 hover:-translate-y-1.5 border border-gray-100 bg-white aspect-square">
                    <img src="{{ asset('images/sdg-4.jpg') }}" alt="Goal 4: Quality Education" class="absolute inset-0 w-full h-full object-cover transition-opacity duration-300 opacity-100 group-hover:opacity-0">
                    <img src="{{ asset('images/sdg-4-inv.jpg') }}" alt="Goal 4: Quality Education" class="absolute inset-0 w-full h-full object-cover transition-opacity duration-300 opacity-0 group-hover:opacity-100">
                </a>

                <a href="{{ path('app_library') }}?goals[]=7" class="block group relative rounded-xl overflow-hidden shadow-sm hover:shadow-2xl transition-all duration-300 hover:-translate-y-1.5 border border-gray-100 bg-white aspect-square">
                    <img src="{{ asset('images/sdg-7.jpg') }}" alt="Goal 7: Affordable and Clean Energy" class="absolute inset-0 w-full h-full object-cover transition-opacity duration-300 opacity-100 group-hover:opacity-0">
                    <img src="{{ asset('images/sdg-7-inv.jpg') }}" alt="Goal 7: Affordable and Clean Energy" class="absolute inset-0 w-full h-full object-cover transition-opacity duration-300 opacity-0 group-hover:opacity-100">
                </a>

                <a href="{{ path('app_library') }}?goals[]=8" class="block group relative rounded-xl overflow-hidden shadow-sm hover:shadow-2xl transition-all duration-300 hover:-translate-y-1.5 border border-gray-100 bg-white aspect-square">
                    <img src="{{ asset('images/sdg-8.jpg') }}" alt="Goal 8: Decent Work and Economic Growth" class="absolute inset-0 w-full h-full object-cover transition-opacity duration-300 opacity-100 group-hover:opacity-0">
                    <img src="{{ asset('images/sdg-8-inv.jpg') }}" alt="Goal 8: Decent Work and Economic Growth" class="absolute inset-0 w-full h-full object-cover transition-opacity duration-300 opacity-0 group-hover:opacity-100">
                </a>

                <a href="{{ path('app_library') }}?goals[]=9" class="block group relative rounded-xl overflow-hidden shadow-sm hover:shadow-2xl transition-all duration-300 hover:-translate-y-1.5 border border-gray-100 bg-white aspect-square">
                    <img src="{{ asset('images/sdg-9.jpg') }}" alt="Goal 9: Industry, Innovation and Infrastructure" class="absolute inset-0 w-full h-full object-cover transition-opacity duration-300 opacity-100 group-hover:opacity-0">
                    <img src="{{ asset('images/sdg-9-inv.jpg') }}" alt="Goal 9: Industry, Innovation and Infrastructure" class="absolute inset-0 w-full h-full object-cover transition-opacity duration-300 opacity-0 group-hover:opacity-100">
                </a>

                <a href="{{ path('app_library') }}?goals[]=11" class="block group relative rounded-xl overflow-hidden shadow-sm hover:shadow-2xl transition-all duration-300 hover:-translate-y-1.5 border border-gray-100 bg-white aspect-square">
                    <img src="{{ asset('images/sdg-11.jpg') }}" alt="Goal 11: Sustainable Cities and Communities" class="absolute inset-0 w-full h-full object-cover transition-opacity duration-300 opacity-100 group-hover:opacity-0">
                    <img src="{{ asset('images/sdg-11-inv.jpg') }}" alt="Goal 11: Sustainable Cities and Communities" class="absolute inset-0 w-full h-full object-cover transition-opacity duration-300 opacity-0 group-hover:opacity-100">
                </a>

                <a href="{{ path('app_library') }}?goals[]=12" class="block group relative rounded-xl overflow-hidden shadow-sm hover:shadow-2xl transition-all duration-300 hover:-translate-y-1.5 border border-gray-100 bg-white aspect-square">
                    <img src="{{ asset('images/sdg-12.jpg') }}" alt="Goal 12: Responsible Consumption and Production" class="absolute inset-0 w-full h-full object-cover transition-opacity duration-300 opacity-100 group-hover:opacity-0">
                    <img src="{{ asset('images/sdg-12-inv.jpg') }}" alt="Goal 12: Responsible Consumption and Production" class="absolute inset-0 w-full h-full object-cover transition-opacity duration-300 opacity-0 group-hover:opacity-100">
                </a>

                <a href="{{ path('app_library') }}?goals[]=17" class="block group relative rounded-xl overflow-hidden shadow-sm hover:shadow-2xl transition-all duration-300 hover:-translate-y-1.5 border border-gray-100 bg-white aspect-square">
                    <img src="{{ asset('images/sdg-17.jpg') }}" alt="Goal 17: Partnerships for the Goals" class="absolute inset-0 w-full h-full object-cover transition-opacity duration-300 opacity-100 group-hover:opacity-0">
                    <img src="{{ asset('images/sdg-17-inv.jpg') }}" alt="Goal 17: Partnerships for the Goals" class="absolute inset-0 w-full h-full object-cover transition-opacity duration-300 opacity-0 group-hover:opacity-100">
                </a>

            </div>
        </div>
    </section>


    <section class="py-20 px-6 bg-white border-t border-gray-200">
        <div class="max-w-7xl mx-auto">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
                <div class="p-8 rounded-2xl bg-green-50">
                    <div class="text-5xl font-black text-green-700 mb-2">{{ total_theses }}</div>
                    <div class="text-gray-600 font-medium">Published Theses</div>
                </div>
                <div class="p-8 rounded-2xl bg-blue-50">
                    <div class="text-5xl font-black text-blue-700 mb-2">45</div>
                    <div class="text-gray-600 font-medium">Community Projects</div>
                </div>
                <div class="p-8 rounded-2xl bg-yellow-50">
                    <div class="text-5xl font-black text-yellow-600 mb-2">8</div>
                    <div class="text-gray-600 font-medium">Active Partnerships</div>
                </div>
            </div>
        </div>
    </section>

    <section class="py-24 px-6 bg-gray-50 border-t border-gray-100">
        <div class="max-w-7xl mx-auto">
            
            <div class="flex justify-between items-end mb-12">
                <div>
                    <h2 class="text-4xl md:text-5xl font-bold text-gray-900 font-bebas tracking-wide mb-3">Latest Updates</h2>
                    <p class="text-lg text-gray-600 font-work">Stay informed with our newest research, seminars, and community events.</p>
                </div>
                <a href="{{ path('app_news') }}" class="hidden md:flex items-center gap-2 text-green-700 font-bold hover:text-[#FCC30B] transition font-work">
                    View All News <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                </a>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                {% for activity in latest_activities %}
                    <article class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden flex flex-col hover:shadow-xl transition duration-300 group">
                        
                        <div class="h-56 relative bg-gray-100 overflow-hidden shrink-0">
                            {% if activity.image %}
                                <img src="{{ asset(activity.image) }}" alt="{{ activity.title }}" class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition duration-500">
                            {% else %}
                                <img src="{{ asset('images/hero-3.jpg') }}" alt="FEU Event" class="absolute inset-0 w-full h-full object-cover opacity-90 group-hover:scale-105 transition duration-500">
                            {% endif %}
                        </div>
                        
                        <div class="p-8 flex flex-col flex-grow">
                            <div class="flex items-center gap-3 mb-4">
                                <span class="bg-green-100 text-green-800 text-[10px] font-bold px-3 py-1 rounded-full uppercase tracking-widest">{{ activity.category }}</span>
                                <span class="text-gray-400 text-xs font-medium">{{ activity.eventDate|date('M j, Y') }}</span>
                            </div>
                            
                            <h3 class="text-2xl font-bold text-gray-900 mb-3 group-hover:text-green-700 transition font-bebas tracking-wide">
                                <a href="#">{{ activity.title }}</a>
                            </h3>
                            
                            <div class="text-gray-600 text-sm leading-relaxed mb-6 line-clamp-2 font-work prose max-w-none">
                                {{ activity.content|raw }}
                            </div>
                            
                            <a href="#" class="text-green-700 font-bold hover:text-[#FCC30B] transition flex items-center gap-1 text-sm mt-auto w-max font-work">
                                Read Article &rarr;
                            </a>
                        </div>
                    </article>
                {% else %}
                    <div class="col-span-3 p-12 text-center bg-white rounded-2xl border border-dashed border-gray-300">
                        <p class="text-gray-500 font-medium font-work">No recent updates found.</p>
                    </div>
                {% endfor %}
            </div>
            
            <div class="mt-8 text-center md:hidden">
                <a href="{{ path('app_news') }}" class="inline-block bg-green-800 text-white px-8 py-3 rounded-full font-bold font-work shadow-md">
                    View All News
                </a>
            </div>

        </div>
    </section>
{% endblock %}