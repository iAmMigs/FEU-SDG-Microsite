{% extends 'SDG-Microsite/base.html.twig' %}

{% block title %}Library - FEU SDG Microsite{% endblock %}

{% block body %}
    <section class="bg-feu-green-900 py-16 px-6 text-center border-b-4 border-feu-gold-400">
        <div class="max-w-4xl mx-auto">
            <h1 class="text-4xl md:text-5xl font-bold text-white mb-4 font-bebas tracking-wide">Research Library</h1>
            <p class="text-lg text-feu-green-50 font-medium font-work max-w-2xl mx-auto">
                Explore student theses and community projects dedicated to sustainable development.
            </p>
        </div>
    </section>

    <section class="py-12 px-6 bg-gray-50 min-h-screen">
        
        <div class="max-w-7xl mx-auto flex flex-col lg:flex-row gap-8" data-controller="autosubmit">
            
            <aside class="w-full lg:w-1/4 flex-shrink-0">
                <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100 sticky top-28">
                    <h2 class="text-lg font-bold text-green-950 mb-6 border-b pb-2 font-bebas tracking-wide">Filter Research</h2>
                    
                    <form id="filter-form" action="{{ path('app_library') }}" method="GET" class="space-y-6"
                          data-autosubmit-target="form"
                          data-action="change->autosubmit#submit input->autosubmit#submit"
                          data-turbo-frame="theses_list">
                        
                        <div>
                            <label for="author" class="block text-sm font-semibold text-gray-700 mb-2 font-work">Search Author</label>
                            <input type="text" id="author" name="author" value="{{ search_author|default('') }}" placeholder="e.g. Dela Cruz" class="w-full rounded-lg border-gray-300 shadow-sm focus:border-green-700 focus:ring-green-700 px-4 py-2 border font-work">
                        </div>

                        <div>
                            <label for="title" class="block text-sm font-semibold text-gray-700 mb-2 font-work">Search Title</label>
                            <input type="text" id="title" name="title" value="{{ search_title|default('') }}" placeholder="Project title..." class="w-full rounded-lg border-gray-300 shadow-sm focus:border-green-700 focus:ring-green-700 px-4 py-2 border font-work">
                        </div>

                        <div>
                            <label for="keyword" class="block text-sm font-semibold text-gray-700 mb-2 font-work">Search Abstract</label>
                            <input type="text" id="keyword" name="keyword" value="{{ search_keyword|default('') }}" placeholder="Specific terms..." class="w-full rounded-lg border-gray-300 shadow-sm focus:border-green-700 focus:ring-green-700 px-4 py-2 border font-work">
                        </div>

                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-3 font-work">Filter by SDG</label>
                            
                            <div class="grid grid-cols-4 gap-2 mb-4">
                                {% set available_goals = [3, 4, 7, 8, 9, 11, 12, 17] %}
                                {% for goal in available_goals %}
                                    <label class="cursor-pointer relative block aspect-square rounded-md overflow-hidden shadow-sm hover:shadow-md transition group border border-gray-100 bg-white">
                                        <input type="checkbox" name="goals[]" value="{{ goal }}" class="peer hidden" {% if selected_goals is defined and goal in selected_goals %}checked{% endif %}>
                                        <img src="{{ asset('images/sdg-' ~ goal ~ '-inv.jpg') }}" alt="SDG {{ goal }}" class="absolute inset-0 w-full h-full object-cover transition-opacity duration-300 opacity-100 peer-checked:opacity-0 group-hover:opacity-75">
                                        <img src="{{ asset('images/sdg-' ~ goal ~ '.jpg') }}" alt="SDG {{ goal }}" class="absolute inset-0 w-full h-full object-cover transition-opacity duration-300 opacity-0 peer-checked:opacity-100">
                                        <div class="absolute inset-0 border-2 border-green-700 rounded-md opacity-0 peer-checked:opacity-100 transition-opacity pointer-events-none"></div>
                                    </label>
                                {% endfor %}
                            </div>

                            <div class="flex items-center bg-gray-50 p-3 rounded-lg border border-gray-200">
                                <input type="checkbox" id="exclusive" name="exclusive" value="1" 
                                       class="w-5 h-5 rounded border-gray-300 text-green-700 focus:ring-green-700 cursor-pointer"
                                       {% if is_exclusive|default(false) %}checked{% endif %}>
                                <label for="exclusive" class="ml-3 text-sm font-semibold text-gray-700 font-work cursor-pointer select-none">
                                    Precise Filtering <span class="block text-xs text-gray-500 font-normal">Show only studies with ALL selected SDGs</span>
                                </label>
                            </div>
                        </div>

                        <noscript>
                            <button type="submit" class="w-full bg-green-800 hover:bg-green-700 text-white font-bold py-3 rounded-lg transition shadow-sm">Search</button>
                        </noscript>
                    </form>
                </div>
            </aside>

            <main class="w-full lg:w-3/4">
                
                <turbo-frame id="theses_list">
                    
                    <div class="flex flex-col sm:flex-row justify-between items-center mb-6 pb-4 border-b border-gray-200 gap-4">
                        <p class="text-gray-600 font-medium font-work">Showing <span class="font-bold text-green-900">{{ total_count|default(0) }}</span> studies found.</p>

                        <div class="flex items-center gap-2 text-sm font-work text-gray-700 bg-white px-3 py-1.5 rounded-lg border border-gray-200 shadow-sm">
                            <span class="hidden sm:inline font-medium mr-1">Page</span>
                            
                            <button type="button" data-action="click->autosubmit#prevPage" class="p-1 text-gray-400 hover:text-green-700 transition {% if current_page|default(1) <= 1 %}opacity-30 cursor-not-allowed pointer-events-none{% endif %}">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
                            </button>
                            
                            <input type="number" name="page" form="filter-form" 
                                   data-autosubmit-target="page" 
                                   data-action="change->autosubmit#submit"
                                   data-max="{{ total_pages|default(1) }}" 
                                   value="{{ current_page|default(1) }}" 
                                   min="1" max="{{ total_pages|default(1) }}"
                                   class="w-14 text-center rounded-md border-gray-200 focus:border-green-700 focus:ring-green-700 py-1 border font-bold text-green-900 bg-gray-50 hide-arrows">
                            
                            <button type="button" data-action="click->autosubmit#nextPage" class="p-1 text-gray-400 hover:text-green-700 transition {% if current_page|default(1) >= total_pages|default(1) %}opacity-30 cursor-not-allowed pointer-events-none{% endif %}">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                            </button>
                            
                            <span class="hidden sm:inline font-medium ml-1">of {{ total_pages|default(1) }}</span>
                        </div>
                    </div>

                    <div id="theses-skeleton" class="space-y-6 hidden">
                        {% for i in 1..3 %}
                        <div class="bg-white rounded-2xl p-8 border border-gray-100 shadow-sm animate-pulse flex flex-col md:flex-row gap-6">
                            <div class="flex-grow">
                                <div class="flex gap-2 mb-4">
                                    <div class="h-6 w-20 bg-gray-200 rounded-full"></div>
                                    <div class="h-6 w-24 bg-gray-200 rounded-full"></div>
                                </div>
                                <div class="h-6 w-3/4 bg-gray-200 rounded mb-3"></div>
                                <div class="h-4 w-full bg-gray-200 rounded mb-2"></div>
                                <div class="h-4 w-5/6 bg-gray-200 rounded mb-4"></div>
                                <div class="flex justify-between items-center mt-6">
                                    <div class="h-4 w-1/4 bg-gray-200 rounded"></div>
                                    <div class="h-4 w-16 bg-gray-200 rounded"></div>
                                </div>
                            </div>
                        </div>
                        {% endfor %}
                    </div>

                    <div id="theses-results" class="space-y-6">
                        {% for thesis in theses %}
                            <article class="bg-white rounded-2xl p-8 border border-gray-100 shadow-sm hover:shadow-lg transition flex flex-col md:flex-row gap-6">
                                <div class="flex-grow">
                                    <div class="flex flex-wrap gap-2 mb-3">
                                        {% for goal in thesis.sdgGoals %}
                                            <span class="bg-green-50 text-green-800 text-xs font-bold px-3 py-1 rounded-full border border-green-200 font-work">
                                                SDG {{ goal.goalNumber }}
                                            </span>
                                        {% endfor %}
                                    </div>
                                    <h3 class="text-2xl font-bold text-gray-900 mb-2 hover:text-green-700 transition font-bebas tracking-wide">
                                        <a href="#">{{ thesis.title }}</a>
                                    </h3>
                                    <p class="text-gray-600 text-sm leading-relaxed mb-4 line-clamp-3 font-work">
                                        {{ thesis.description }}
                                    </p>
                                    <div class="flex items-center justify-between text-sm text-gray-500 mt-auto font-work">
                                        <span class="font-medium">By {{ thesis.authors }}</span>
                                        <div class="flex items-center text-green-700 font-bold gap-1">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                                            {{ thesis.views|number_format }}
                                        </div>
                                    </div>
                                </div>
                            </article>
                        {% else %}
                            <div class="p-12 text-center bg-white rounded-2xl border border-dashed border-gray-300">
                                <p class="text-gray-500 font-medium font-work">No projects found for the selected filters.</p>
                            </div>
                        {% endfor %}
                    </div>

                </turbo-frame>
            </main>
        </div>
    </section>
{% endblock %}