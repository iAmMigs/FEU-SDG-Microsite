{# templates/SDG-Microsite/news/index.html.twig #}
{% extends 'SDG-Microsite/base.html.twig' %}

{# ADDED: Turbo Cache Control from Library #}
{% block head %}
    {{ parent() }}
    <meta name="turbo-cache-control" content="no-cache">
{% endblock %}

{% block title %}News & Activities - FEU SDG Microsite{% endblock %}

{% block body %}
    <section class="bg-feu-green-900 py-16 px-6 text-center border-b-4 border-feu-gold-400">
        <div class="max-w-4xl mx-auto">
            <h1 class="text-4xl md:text-5xl font-bold text-white mb-4 font-bebas tracking-wide">News & Activities</h1>
            <p class="text-lg text-feu-green-50 font-medium font-work max-w-2xl mx-auto">
                Stay informed with our newest research, seminars, and community events.
            </p>
        </div>
    </section>

    <section class="py-12 bg-gray-50 min-h-screen">
        <div class="max-w-7xl mx-auto px-8 md:px-16 lg:px-24">
            
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 mb-10 z-10 relative">
                
                {# 
                   LIBRARY LOGIC APPLIED:
                   1. data-turbo-frame="news_list"
                   2. data-action="change->autosubmit#submit input->autosubmit#submit"
                #}
                <form id="filter-form" action="{{ path('app_news') }}" method="GET" 
                      data-controller="autosubmit" 
                      data-autosubmit-target="form"
                      data-action="change->autosubmit#submit input->autosubmit#submit"
                      data-turbo-frame="news_list"
                      autocomplete="off">
                    
                    <input type="hidden" name="page" data-autosubmit-target="page" value="{{ current_page|default(1) }}">

                    <div class="flex flex-col lg:flex-row gap-8 items-start lg:items-center">
                        <div class="w-full lg:w-1/4 shrink-0">
                            <label for="date_range" class="block text-xs font-bold text-gray-400 mb-2 font-work uppercase tracking-widest">Timeframe</label>
                            <select id="date_range" name="date_range" class="w-full rounded-xl border-gray-200 shadow-sm focus:border-feu-green-700 focus:ring-feu-green-700 px-4 py-3 bg-gray-50 font-work text-gray-800 font-bold cursor-pointer transition hover:bg-gray-100">
                                <option value="">Anytime</option>
                                <option value="1_day" {% if date_range == '1_day' %}selected{% endif %}>Past 24 Hours</option>
                                <option value="7_days" {% if date_range == '7_days' %}selected{% endif %}>Past 7 Days</option>
                                <option value="30_days" {% if date_range == '30_days' %}selected{% endif %}>Past Month</option>
                            </select>
                        </div>

                        <div class="w-full lg:w-3/4">
                            <label class="block text-xs font-bold text-gray-400 mb-2 font-work uppercase tracking-widest">Filter by Goal</label>
                            <div class="flex flex-wrap gap-3">
                                {# LOOP THROUGH THE DATABASE ENTITIES INSTEAD OF HARDCODED ARRAY #}
                                {% for sdg in all_sdgs %}
                                    {% set formatted_num = '%02d'|format(sdg.id) %}
                                    
                                    <label class="cursor-pointer relative block w-14 h-14 rounded-md overflow-hidden shadow-sm hover:shadow-md transition group border border-gray-100 bg-white shrink-0">
                                        
                                        <input type="checkbox" name="goals[]" value="{{ sdg.id }}" class="peer sr-only" 
                                            {% if selected_goals is defined and sdg.id ~ '' in selected_goals %}checked{% endif %}>
                                        
                                        <img src="{{ asset('images/sdg/E Inverted Icons_WEB-' ~ formatted_num ~ '.png') }}" alt="Goal {{ sdg.id }}" class="absolute inset-0 w-full h-full object-cover transition-opacity duration-300 opacity-100 peer-checked:opacity-0 group-hover:opacity-75">
                                        
                                        <img src="{{ asset('images/sdg/E-WEB-Goal-' ~ formatted_num ~ '.png') }}" alt="Goal {{ sdg.id }}" class="absolute inset-0 w-full h-full object-cover transition-opacity duration-300 opacity-0 peer-checked:opacity-100">
                                        
                                        <div class="absolute inset-0 border-2 border-feu-green-700 rounded-md opacity-0 peer-checked:opacity-100 transition-opacity pointer-events-none"></div>
                                    </label>
                                {% endfor %}
                            </div>
                        </div>
                    </div>
                </form>
            </div>

            <turbo-frame id="news_list">
                
                {# LIBRARY LOGIC: The Skeleton Loader #}
                <div id="news-skeleton" class="hidden flex-wrap justify-center gap-8 mb-8">
                    {% for i in 1..3 %}
                        <article class="w-full sm:w-[calc(50%-1rem)] lg:w-[calc(33.333%-1.34rem)] bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden flex flex-col max-w-md h-[28rem] animate-pulse">
                            <div class="h-64 bg-gray-200 shrink-0"></div>
                            <div class="p-8 flex flex-col flex-grow gap-4">
                                <div class="flex gap-2">
                                    <div class="h-5 bg-gray-200 rounded-full w-16"></div>
                                    <div class="h-5 bg-gray-200 rounded w-16"></div>
                                </div>
                                <div class="h-6 bg-gray-200 rounded w-full mt-2"></div>
                                <div class="h-6 bg-gray-200 rounded w-3/4"></div>
                                <div class="h-10 bg-gray-200 rounded w-full mt-auto"></div>
                            </div>
                        </article>
                    {% endfor %}
                </div>

                {# LIBRARY LOGIC: The Dynamic Results #}
                <div id="news-results" class="flex flex-wrap justify-center gap-8">
                    {% for activity in activities %}
                        <article class="w-full sm:w-[calc(50%-1rem)] lg:w-[calc(33.333%-1.34rem)] bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden flex flex-col hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group max-w-md">
                            
                            <div class="h-64 relative bg-gray-100 overflow-hidden shrink-0">
                                {% if activity.image %}
                                    <img src="{{ asset('uploads/activities/' ~ activity.image) }}" alt="{{ activity.title }}" class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700">
                                {% else %}
                                    <img src="{{ asset('images/hero-3.jpg') }}" alt="Default" class="absolute inset-0 w-full h-full object-cover opacity-90">
                                {% endif %}
                            </div>

                            <div class="p-8 flex flex-col flex-grow">
                                <div class="flex flex-wrap items-center gap-2 mb-4">
                                    <span class="bg-feu-green-900 text-white text-[10px] font-bold px-3 py-1 rounded-full uppercase tracking-widest shadow-sm">
                                        {{ activity.category }}
                                    </span>
                                    
                                    {% for sdg in activity.sdgs %}
                                        <span class="bg-gray-100 text-gray-600 text-[10px] font-bold px-2 py-1 rounded-md border border-gray-200 font-work uppercase">
                                            SDG {{ sdg.id }}
                                        </span>
                                    {% endfor %}
                                </div>
                                
                                <span class="text-gray-400 text-xs font-bold font-work flex items-center gap-1.5 mb-3">
                                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4 text-feu-green-700">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
                                    </svg>
                                    {{ activity.eventDate|date('M j, Y') }}
                                </span>
                                
                                <h3 class="text-2xl font-bold text-gray-900 mb-4 group-hover:text-feu-green-700 transition-colors font-bebas tracking-wide leading-tight">
                                    <a href="{{ path('app_news_show', {id: activity.id}) }}" data-turbo-frame="_top">{{ activity.title }}</a>
                                </h3>
                                
                                <div class="text-gray-600 text-sm leading-relaxed mb-8 line-clamp-5 font-work">
                                    <p>{{ activity.content|striptags|replace({'&nbsp;': ' '})|trim }}</p>
                                </div>
                                
                                <a href="{{ path('app_news_show', {id: activity.id}) }}" data-turbo-frame="_top" class="mt-auto inline-flex items-center justify-center w-full py-3 bg-gray-50 hover:bg-feu-green-800 text-gray-800 hover:text-white font-bold rounded-xl transition-all duration-300 font-work text-sm group/btn">
                                    Read Article &rarr;
                                </a>
                            </div>
                        </article>
                    {% else %}
                        <div class="w-full p-16 text-center bg-white rounded-3xl border border-dashed border-gray-300">
                            <p class="text-gray-500 font-medium font-work text-lg">No activities found matching your filters.</p>
                        </div>
                    {% endfor %}
                </div>
            </turbo-frame>
        </div>
    </section>
{% endblock %}