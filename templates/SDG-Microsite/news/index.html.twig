{% extends 'SDG-Microsite/base.html.twig' %}

{% block title %}News & Activities - FEU SDG Microsite{% endblock %}

{% block body %}
    <section class="bg-feu-green-900 py-16 px-6 text-center border-b-4 border-feu-gold-400">
        <div class="max-w-4xl mx-auto">
            <h1 class="text-4xl md:text-5xl font-bold text-white mb-4 font-bebas tracking-wide">News & Activities</h1>
            <p class="text-lg text-feu-green-50 font-medium font-work max-w-2xl mx-auto">
                Stay informed with our newest research, seminars, and community events.
            </p>
        </div>
    </section>

    <section class="py-16 px-6 bg-gray-50 min-h-screen">
        <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {% for activity in activities %}
                <article class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden flex flex-col hover:shadow-xl transition duration-300 group">
                    
                    <div class="h-56 relative bg-gray-100 overflow-hidden shrink-0">
                        {% if activity.image %}
                            <img src="{{ asset('uploads/activities/' ~ activity.image) }}" alt="{{ activity.title }}" class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition duration-500">
                        {% else %}
                            <img src="{{ asset('images/hero-3.jpg') }}" alt="Fallback Event Image" class="absolute inset-0 w-full h-full object-cover opacity-90 group-hover:scale-105 transition duration-500">
                        {% endif %}
                    </div>

                    <div class="p-8 flex flex-col flex-grow">
                        <div class="flex items-center justify-between mb-4">
                            <span class="bg-feu-green-100 text-feu-green-800 text-[10px] font-bold px-3 py-1 rounded-full uppercase tracking-widest">{{ activity.category }}</span>
                            <span class="text-gray-400 text-xs font-medium">{{ activity.eventDate|date('M j, Y') }}</span>
                        </div>
                        
                        <h3 class="text-2xl font-bold text-gray-900 mb-3 group-hover:text-feu-green-700 transition font-bebas tracking-wide">
                            <a href="#">{{ activity.title }}</a>
                        </h3>
                        
                        <div class="text-gray-600 text-sm leading-relaxed mb-6 line-clamp-3 font-work">
                            <p class="whitespace-pre-line">{{ activity.content }}</p>
                        </div>
                        
                        <a href="#" class="text-feu-green-700 font-bold hover:text-[#FCC30B] transition flex items-center gap-1 text-sm mt-auto w-max font-work">
                            Read Full Article &rarr;
                        </a>
                    </div>
                </article>
            {% else %}
                <div class="col-span-1 md:col-span-2 lg:col-span-3 p-12 text-center bg-white rounded-2xl border border-dashed border-gray-300">
                    <p class="text-gray-500 font-medium font-work">No activities have been posted yet.</p>
                </div>
            {% endfor %}
        </div>
    </section>
{% endblock %}