{% extends 'SDG-Microsite/base.html.twig' %}

{% block title %}{{ activity.title }} - FEU SDG Microsite{% endblock %}

{% block body %}
{# Calculate Estimated Reading Time (Average 200 words per minute) #}
{% set word_count = activity.content|striptags|split(' ')|length %}
{% set reading_time = (word_count / 200)|round(0, 'ceil') %}

{# Define SDG Colors for the tags #}
{% set sdg_colors = {
    1: '#E5243B', 2: '#DDA63A', 3: '#4C9F38', 4: '#C5192D', 5: '#FF3A21', 6: '#26BDE2',
    7: '#FCC30B', 8: '#A21942', 9: '#FD6925', 10: '#DD1367', 11: '#FD9D24', 12: '#BF8B2E',
    13: '#3F7E44', 14: '#0A97D9', 15: '#56C02B', 16: '#00689D', 17: '#19486A'
} %}

<section class="bg-gray-50 py-12 px-6 min-h-screen">
    <div class="max-w-4xl mx-auto">
        
        <a href="{{ path('app_news') }}" class="text-gray-500 hover:text-feu-green-700 font-bold text-sm mb-8 inline-flex items-center gap-2 transition font-work group">
            <svg class="w-4 h-4 transition-transform group-hover:-translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
            </svg>
            Back to News & Activities
        </a>

        <article class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden">
            
            {# Hero Image Header #}
            <div class="w-full h-64 md:h-[32rem] relative bg-gray-100 overflow-hidden shrink-0 border-b-4 border-feu-gold-400">
                {% if activity.image %}
                    <img src="{{ asset('uploads/activities/' ~ activity.image) }}" alt="{{ activity.title }}" class="absolute inset-0 w-full h-full object-cover">
                {% else %}
                    <img src="{{ asset('images/hero-3.jpg') }}" alt="FEU Event" class="absolute inset-0 w-full h-full object-cover opacity-90">
                {% endif %}
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent"></div>
            </div>

            <div class="p-8 md:p-12 lg:p-16">
                {# Metadata & SDG Tags #}
                <div class="flex flex-wrap items-center gap-3 mb-8">
                    {# Category Tag #}
                    <span class="bg-feu-green-900 text-white text-[10px] font-bold px-3 py-1.5 rounded-full uppercase tracking-widest font-work shadow-sm">
                        {{ activity.category }}
                    </span>
                    
                    {# The Colored SDG Tags right next to the category #}
                    {% for sdg in activity.sdgs %}
                        <span class="text-white text-[10px] font-bold px-3 py-1.5 rounded-full font-work uppercase tracking-wider shadow-sm" style="background-color: {{ sdg_colors[sdg.id]|default('#166534') }}; text-shadow: 0px 1px 2px rgba(0,0,0,0.2);">
                            SDG {{ sdg.id }}
                        </span>
                    {% endfor %}
                    
                    <div class="h-4 w-px bg-gray-300 hidden sm:block ml-1"></div>
                    
                    <span class="text-gray-500 font-bold font-work text-sm flex items-center gap-1.5">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                        {{ activity.eventDate|date('F j, Y') }}
                    </span>

                    <div class="h-4 w-px bg-gray-300 hidden sm:block"></div>

                    <span class="text-gray-500 font-bold font-work text-sm flex items-center gap-1.5">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        {{ reading_time }} min read
                    </span>
                </div>
                
                {# Article Title #}
                <h1 class="text-4xl md:text-6xl font-bold text-gray-950 mb-10 font-bebas tracking-wide leading-[1.1] pb-8 border-b border-gray-100">
                    {{ activity.title }}
                </h1>
                
                {# Article Content Workspace #}
                <div class="prose prose-lg lg:prose-xl max-w-none text-gray-800 font-work leading-relaxed
                            prose-headings:font-bebas prose-headings:tracking-wide prose-headings:text-feu-green-950
                            prose-img:rounded-3xl prose-img:shadow-2xl prose-img:border prose-img:border-gray-100 prose-img:my-12
                            prose-a:text-feu-green-700 prose-a:no-underline hover:prose-a:underline prose-strong:text-black">
                    
                    {{ activity.content|raw }}
                    
                </div>
            </div>
            
        </article>

    </div>
</section>
{% endblock %}