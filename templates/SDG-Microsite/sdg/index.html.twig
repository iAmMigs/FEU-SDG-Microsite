{% extends 'SDG-Microsite/base.html.twig' %}

{% block title %}Our SDG Focus - FEU SDG Microsite{% endblock %}

{% block body %}
    <div class="relative min-h-screen bg-gray-50 pb-24">
        
        <section class="bg-feu-green-900 py-16 px-6 text-center border-b-4 border-feu-gold-400 mb-16">
            <div class="max-w-4xl mx-auto">
                <h1 class="text-5xl md:text-6xl font-bold text-white mb-6 font-bebas tracking-wide">Our Global Focus</h1>
                <p class="text-xl text-feu-green-50 font-medium font-work max-w-2xl mx-auto leading-relaxed">
                    FEU is committed to the United Nations Sustainable Development Goals. Explore our primary areas of impact below.
                </p>
            </div>
        </section>

        <div data-controller="modal" class="max-w-7xl mx-auto px-6 relative z-10">
            
            <div class="flex justify-center mb-10">
                <div class="bg-gray-200 p-1 rounded-full flex gap-1 shadow-inner relative z-20">
                    <button type="button"
                            id="btn-focused-sdgs"
                            onclick="window.filterSdgs('focused')"
                            class="px-6 py-2 rounded-full text-sm font-bold font-work transition-all duration-300 bg-feu-green-900 text-white shadow-md cursor-pointer">
                        Focused SDGs
                    </button>
                    <button type="button"
                            id="btn-all-sdgs"
                            onclick="window.filterSdgs('all')"
                            class="px-6 py-2 rounded-full text-sm font-bold font-work transition-all duration-300 bg-gray-200 text-gray-600 hover:bg-gray-300 cursor-pointer">
                        All SDGs
                    </button>
                </div>
            </div>

            <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-6 lg:gap-8">
                {% for sdg in all_sdgs %}
                    {% set formatted_num = '%02d'|format(sdg.num) %}
                    {% set is_active = sdg.num in active_sdg_ids %}
                    
                    <button type="button" 
                            data-modal-target="card"
                            data-action="click->modal#open"
                            data-goal="{{ sdg.num }}"
                            data-title="{{ sdg.title }}"
                            data-description="{{ sdg.long_desc }}"
                            data-active="{{ is_active ? 'true' : 'false' }}"
                            data-image="{{ asset('images/sdg/E-WEB-Goal-' ~ formatted_num ~ '.png') }}"
                            style="{{ is_active ? 'display: block; opacity: 1; transform: scale(1);' : 'display: none; opacity: 0; transform: scale(0.95);' }}"
                            class="sdg-card mt-6 block group relative rounded-2xl overflow-hidden shadow-md hover:shadow-2xl transition-all duration-300 hover:-translate-y-2 border border-gray-100 bg-white aspect-square text-left focus:outline-none focus:ring-4 focus:ring-green-700/30 cursor-pointer">
                        
                        <img src="{{ asset('images/sdg/E-WEB-Goal-' ~ formatted_num ~ '.png') }}" alt="Goal {{ sdg.num }}" class="absolute inset-0 w-full h-full object-cover transition-opacity duration-300 opacity-100 group-hover:opacity-0">
                        <img src="{{ asset('images/sdg/E Inverted Icons_WEB-' ~ formatted_num ~ '.png') }}" alt="Goal {{ sdg.num }}" class="absolute inset-0 w-full h-full object-cover transition-opacity duration-300 opacity-0 group-hover:opacity-100">
                    </button>
                {% endfor %}
            </div>

            <div data-modal-target="backdrop" class="fixed inset-0 z-[100] hidden opacity-0 transition-opacity duration-300 flex items-center justify-center p-4 md:p-6">
                <div class="absolute inset-0 bg-black/60 backdrop-blur-md cursor-pointer" data-action="click->modal#close"></div>
                
                <div data-modal-target="panel" class="relative bg-white rounded-3xl overflow-hidden shadow-2xl w-full max-w-4xl flex flex-col md:flex-row transform opacity-0 scale-95 translate-y-4 transition-all duration-300 ease-out z-10 max-h-[90vh]">
                    
                    {# Close Button (Simplified to match reference) #}
                    <button type="button" data-action="click->modal#close" class="absolute top-6 right-6 z-20 text-gray-400 hover:text-gray-800 transition duration-200 focus:outline-none cursor-pointer">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                    </button>

                    {# LEFT SIDE: Image properly contained with padding to match home page #}
                    <div class="md:w-1/2 p-8 md:p-12 flex items-center justify-center bg-white shrink-0">
                        <img data-modal-target="image" src="" alt="SDG Target Cover" class="w-full max-w-[320px] h-auto object-contain shadow-sm">
                    </div>
                    
                    {# RIGHT SIDE: Content, Title, and Buttons #}
                    <div class="md:w-1/2 p-8 md:p-12 md:pl-0 flex flex-col justify-center bg-white overflow-y-auto">
                        <div class="flex-grow flex flex-col justify-center">
                            
                            <h2 data-modal-target="title" class="text-3xl md:text-4xl font-bold text-feu-green-950 mb-4 font-bebas tracking-wide leading-tight uppercase pr-8">
                                Goal Title
                            </h2>
                            
                            <p data-modal-target="description" class="text-gray-600 text-sm md:text-base leading-relaxed font-work">
                                Goal Description
                            </p>
                        </div>
                        
                        <div class="mt-8 pt-6 border-t border-gray-100 flex flex-col gap-4 text-center shrink-0">
                            <h4 data-modal-target="actionPrompt" class="text-xs font-bold text-gray-400 uppercase tracking-widest font-work">Which would you like to visit?</h4>
                            
                            <div data-modal-target="buttonsContainer" class="flex flex-col gap-3">
                                {# Library Button (Green) #}
                                <a href="#" data-modal-target="libraryBtn" class="block w-full text-center bg-feu-green-900 text-white font-bold px-5 py-3.5 rounded-xl hover:bg-feu-green-800 transition duration-300 font-work shadow-sm text-sm">
                                    SDG Related Project Library
                                </a>

                                {# Activities Button (Gold/Yellow) #}
                                <a href="#" data-modal-target="activityBtn" class="block w-full text-center bg-[#FCC30B] text-yellow-950 font-bold px-5 py-3.5 rounded-xl hover:bg-yellow-500 transition duration-300 font-work shadow-sm text-sm">
                                    SDG Related Activities
                                </a>
                            </div>
                        </div>
                    </div>
                    
                </div>
            </div>

            <script>
                // Use the window object to prevent "Identifier has already been declared" errors in Turbo
                window.currentSdgMode = 'focused'; 

                window.filterSdgs = function(mode) {
                    if (window.currentSdgMode === mode) return;
                    window.currentSdgMode = mode;

                    const btnAll = document.getElementById('btn-all-sdgs');
                    const btnFocused = document.getElementById('btn-focused-sdgs');
                    const cards = document.querySelectorAll('.sdg-card');

                    if (mode === 'all') {
                        btnAll.className = "px-6 py-2 rounded-full text-sm font-bold font-work transition-all duration-300 bg-feu-green-900 text-white shadow-md cursor-pointer";
                        btnFocused.className = "px-6 py-2 rounded-full text-sm font-bold font-work transition-all duration-300 bg-gray-200 text-gray-600 hover:bg-gray-300 cursor-pointer";
                    } else {
                        btnFocused.className = "px-6 py-2 rounded-full text-sm font-bold font-work transition-all duration-300 bg-feu-green-900 text-white shadow-md cursor-pointer";
                        btnAll.className = "px-6 py-2 rounded-full text-sm font-bold font-work transition-all duration-300 bg-gray-200 text-gray-600 hover:bg-gray-300 cursor-pointer";
                    }

                    cards.forEach(card => {
                        const isActive = card.dataset.active === 'true';
                        const shouldShow = mode === 'all' || isActive;

                        if (shouldShow) {
                            card.style.display = 'block';
                            requestAnimationFrame(() => {
                                card.style.opacity = '1';
                                card.style.transform = 'scale(1)';
                            });
                        } else {
                            card.style.opacity = '0';
                            card.style.transform = 'scale(0.95)';
                            setTimeout(() => {
                                if (window.currentSdgMode === 'focused' && !isActive) {
                                    card.style.display = 'none';
                                }
                            }, 300);
                        }
                    });
                }
            </script>
        </div>
    </div>
{% endblock %}