{% extends 'base.html.twig' %}

{% block title %}Project Library - FEU SDG Microsite{% endblock %}

{% block body %}
    <section class="bg-green-900 py-16 px-6 relative overflow-hidden">
        <div class="relative max-w-7xl mx-auto z-10 text-center md:text-left">
            <h1 class="text-3xl md:text-5xl font-bold text-white tracking-tight mb-4">SDG Theses Repository</h1>
            <p class="text-green-100 text-lg max-w-2xl">
                Browse, search, and discover student-led research and projects dedicated to for the betterment of communities and companies in alignment with the United Nations Sustainable Development Goals.
            </p>
        </div>
    </section>

    <section class="py-12 px-6 bg-gray-50 min-h-screen">
        <div class="max-w-7xl mx-auto flex flex-col lg:flex-row gap-8">
            
            <aside class="w-full lg:w-1/4 flex-shrink-0">
                <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100 sticky top-28">
                    <h2 class="text-lg font-bold text-green-950 mb-6 border-b pb-2">Filter Research</h2>
                    
                    <form action="{{ path('app_library') }}" method="GET" class="space-y-6">
                        
                        <div>
                            <label for="q" class="block text-sm font-semibold text-gray-700 mb-2">Search Keyword</label>
                            <input type="text" id="q" name="q" placeholder="Title, author, abstract..." class="w-full rounded-lg border-gray-300 shadow-sm focus:border-green-700 focus:ring-green-700 px-4 py-2 border">
                        </div>

                        <div>
                            <label for="goal" class="block text-sm font-semibold text-gray-700 mb-2">Filter by SDG</label>
                            <select id="goal" name="goal" class="w-full rounded-lg border-gray-300 shadow-sm focus:border-green-700 focus:ring-green-700 px-4 py-2 border bg-white">
                                <option value="">All</option>
                                <option value="3">Goal 3: Good Health</option>
                                <option value="4">Goal 4: Quality Education</option>
                                <option value="7">Goal 7: Clean Energy</option>
                                <option value="8">Goal 8: Economic Growth</option>
                                <option value="9">Goal 9: Industry & Innovation</option>
                                <option value="11">Goal 11: Sustainable Cities</option>
                                <option value="12">Goal 12: Responsible Consumption</option>
                                <option value="17">Goal 17: Partnerships</option>
                            </select>
                        </div>

                        <div>
                            <label for="year" class="block text-sm font-semibold text-gray-700 mb-2">Publication Year</label>
                            <select id="year" name="year" class="w-full rounded-lg border-gray-300 shadow-sm focus:border-green-700 focus:ring-green-700 px-4 py-2 border bg-white">
                                <option value="">All Years</option>
                                <option value="2026">2026</option>
                                <option value="2025">2025</option>
                                <option value="2024">2024</option>
                            </select>
                        </div>

                        <button type="submit" class="w-full bg-green-800 hover:bg-green-700 text-white font-bold py-3 rounded-lg transition shadow-sm">
                            Search
                        </button>
                    </form>
                </div>
            </aside>

            <main class="w-full lg:w-3/4">
                
                <div class="flex justify-between items-center mb-6">
                    <p class="text-gray-600 font-medium">Showing <span class="font-bold text-green-900">3</span> studies found.</p>
                    <div class="flex items-center gap-2 text-sm">
                        <label for="sort" class="text-gray-500">Sort by:</label>
                        <select id="sort" class="border-gray-300 rounded-md shadow-sm py-1 px-2 border bg-white text-gray-700">
                            <option>Newest First</option>
                            <option>Relevance</option>
                            <option>A-Z</option>
                        </select>
                    </div>
                </div>

                <div class="space-y-6">
                    
                    {# SKELETON ITEM 1 #}
                    <article class="bg-white p-6 rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition duration-300 flex flex-col md:flex-row gap-6">
                        <div class="flex-grow">
                            <div class="flex flex-wrap gap-2 mb-3">
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold bg-[#FCC30B] text-yellow-950">
                                    SDG 7: Clean Energy
                                </span>
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold bg-[#FD9D24] text-orange-950">
                                    SDG 11: Sustainable Cities
                                </span>
                            </div>
                            <h3 class="text-xl font-bold text-gray-900 mb-1 hover:text-green-700">
                                <a href="#">Development of a Solar-Powered Water Filtration System for Rural Communities</a>
                            </h3>
                            <p class="text-sm text-gray-500 mb-4">By Miguel Osinada; Published: May 2025 &bull; Engineering</p>
                            <p class="text-gray-600 text-sm leading-relaxed line-clamp-3 mb-4">
                                This study explores the feasibility and efficiency of integrating solar panels with portable water filtration units to provide clean drinking water in off-grid rural communities in the Philippines. The prototype demonstrated a 95% success rate in removing common waterborne pathogens...
                            </p>
                            <a href="#" class="text-green-700 font-semibold hover:text-[#FCC30B] text-sm flex items-center gap-1 transition">
                                Read Full Abstract &rarr;
                            </a>
                        </div>
                    </article>

                    {# SKELETON ITEM 2 #}
                    <article class="bg-white p-6 rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition duration-300 flex flex-col md:flex-row gap-6">
                        <div class="flex-grow">
                            <div class="flex flex-wrap gap-2 mb-3">
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold bg-[#C5192D] text-white">
                                    SDG 4: Quality Education
                                </span>
                            </div>
                            <h3 class="text-xl font-bold text-gray-900 mb-1 hover:text-green-700">
                                <a href="#">Impact of AI-Assisted Tutoring on Engineering Students' Math Proficiency</a>
                            </h3>
                            <p class="text-sm text-gray-500 mb-4">By Anna Reyes &bull; Published: December 2024 &bull; Computer Science</p>
                            <p class="text-gray-600 text-sm leading-relaxed line-clamp-3 mb-4">
                                Analyzing the effectiveness of machine learning algorithms in creating personalized tutoring modules for freshman engineering students struggling with advanced calculus. The research indicates a significant improvement in retention rates when AI tools are utilized alongside traditional lectures.
                            </p>
                            <a href="#" class="text-green-700 font-semibold hover:text-[#FCC30B] text-sm flex items-center gap-1 transition">
                                Read Full Abstract &rarr;
                            </a>
                        </div>
                    </article>

                </div>

                <div class="mt-10 flex justify-center">
                    <nav class="isolate inline-flex -space-x-px rounded-md shadow-sm" aria-label="Pagination">
                        <a href="#" class="relative inline-flex items-center rounded-l-md px-3 py-2 text-gray-400 ring-1 ring-inset ring-gray-300 hover:bg-gray-50 focus:z-20 focus:outline-offset-0">
                            <span class="sr-only">Previous</span>
                            &larr;
                        </a>
                        <a href="#" aria-current="page" class="relative z-10 inline-flex items-center bg-green-800 px-4 py-2 text-sm font-semibold text-white focus:z-20 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-green-800">1</a>
                        <a href="#" class="relative inline-flex items-center px-4 py-2 text-sm font-semibold text-gray-900 ring-1 ring-inset ring-gray-300 hover:bg-gray-50 focus:z-20 focus:outline-offset-0">2</a>
                        <a href="#" class="relative inline-flex items-center px-4 py-2 text-sm font-semibold text-gray-900 ring-1 ring-inset ring-gray-300 hover:bg-gray-50 focus:z-20 focus:outline-offset-0">3</a>
                        <a href="#" class="relative inline-flex items-center rounded-r-md px-3 py-2 text-gray-400 ring-1 ring-inset ring-gray-300 hover:bg-gray-50 focus:z-20 focus:outline-offset-0">
                            <span class="sr-only">Next</span>
                            &rarr;
                        </a>
                    </nav>
                </div>

            </main>
        </div>
    </section>
{% endblock %}