{% extends 'base.html.twig' %}

{% block title %}FEU SDG Microsite - Advancing Sustainability{% endblock %}

{% block body %}
    <section class="relative bg-green-900 text-white py-24 px-6 md:py-32">
        <div class="absolute inset-0 overflow-hidden opacity-20">
            <img src="{{ asset('images/hero-bg.jpg') }}" alt="FEU Campus" class="w-full h-full object-cover">
        </div>
        <div class="relative max-w-7xl mx-auto flex flex-col items-center text-center z-10">
            <h1 class="text-4xl md:text-6xl font-bold tracking-tight mb-6">
                Driving Sustainable Impact at FEU
            </h1>
            <p class="text-lg md:text-xl max-w-3xl mb-10 text-green-50">
                Explore our research, student theses, and community projects dedicated to solving global challenges through local action.
            </p>
            <a href="#goals" class="bg-[#FCC30B] text-green-950 px-8 py-3 rounded-full font-semibold hover:bg-yellow-300 transition duration-300">
                Explore Our Focus Goals
            </a>
        </div>
    </section>

    <section id="goals" class="py-20 px-6 bg-gray-50">
